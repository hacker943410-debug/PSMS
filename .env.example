DATABASE_URL="file:./dev.db"
AUTH_SECRET="replace-with-local-secret"
PASSWORD_TOKEN_SECRET="replace-with-local-token-secret"
CREDENTIAL_COMPLETION_SECRET="replace-with-local-completion-secret"
PSMS_LOGIN_RATE_LIMIT_STORE="file"
# Local default is .tmp/runtime/login-rate-limit.json. Production must set this explicitly.
# PSMS_LOGIN_RATE_LIMIT_FILE=".tmp/runtime/login-rate-limit.json"
PSMS_CREDENTIAL_RATE_LIMIT_STORE="file"
# Local default is .tmp/runtime/credential-token-rate-limit.json. Production must set this explicitly.
# PSMS_CREDENTIAL_RATE_LIMIT_FILE=".tmp/runtime/credential-token-rate-limit.json"
PSMS_ADMIN_CREDENTIAL_RATE_LIMIT_STORE="file"
# Local default is .tmp/runtime/admin-credential-rate-limit.json. Production must set this explicitly.
# PSMS_ADMIN_CREDENTIAL_RATE_LIMIT_FILE=".tmp/runtime/admin-credential-rate-limit.json"
# Optional dedicated HMAC secret for admin credential mutation rate-limit state.
# PSMS_ADMIN_CREDENTIAL_RATE_LIMIT_SECRET=""
# Credential issue stays unavailable until both mode and delivery webhook are configured.
# PSMS_CREDENTIAL_DELIVERY_MODE="OUT_OF_BAND_APPROVED"
# PSMS_CREDENTIAL_DELIVERY_WEBHOOK_URL="https://credential-delivery.your-domain.com/psms"
# PSMS_CREDENTIAL_DELIVERY_WEBHOOK_SECRET=""
# Optional local/test tuning. Production release gate permits timeout 1000..5000 and max attempts 1 only.
# PSMS_CREDENTIAL_DELIVERY_WEBHOOK_TIMEOUT_MS="5000"
# PSMS_CREDENTIAL_DELIVERY_WEBHOOK_MAX_ATTEMPTS="1"

# PSMS local ports:
# Web/App: http://127.0.0.1:5273
# API: http://127.0.0.1:4273
WEB_HOST="127.0.0.1"
WEB_PORT="5273"
API_HOST="127.0.0.1"
API_PORT="4273"
APP_URL="http://127.0.0.1:5273"
PSMS_API_URL="http://127.0.0.1:4273"
# Development-only. Code ignores this bypass in NODE_ENV=production or test.
PSMS_DEV_AUTH_BYPASS="true"
PSMS_SEED_ADMIN_LOGIN_ID="admin1001"
PSMS_SEED_STAFF_LOGIN_ID="staff1001"
PSMS_SEED_ADMIN_PASSWORD=""
PSMS_SEED_STAFF_PASSWORD=""
SEED_RESET_PASSWORDS="false"
SEED_RESET_PASSWORD_LOGIN_IDS=""
PSMS_MASTER_SEED_PASSWORD=""
