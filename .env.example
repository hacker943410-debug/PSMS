DATABASE_URL="file:./dev.db"
AUTH_SECRET="replace-with-local-secret"
PSMS_LOGIN_RATE_LIMIT_STORE="file"
# Local default is .tmp/runtime/login-rate-limit.json. Production must set this explicitly.
# PSMS_LOGIN_RATE_LIMIT_FILE=".tmp/runtime/login-rate-limit.json"

# PSMS local ports:
# Web/App: http://127.0.0.1:5273
# API: http://127.0.0.1:4273
WEB_HOST="127.0.0.1"
WEB_PORT="5273"
API_HOST="127.0.0.1"
API_PORT="4273"
APP_URL="http://127.0.0.1:5273"
PSMS_API_URL="http://127.0.0.1:4273"
# Development-only. Code ignores this bypass in NODE_ENV=production or test.
PSMS_DEV_AUTH_BYPASS="true"
PSMS_SEED_ADMIN_LOGIN_ID="admin1001"
PSMS_SEED_STAFF_LOGIN_ID="staff1001"
PSMS_SEED_ADMIN_PASSWORD=""
PSMS_SEED_STAFF_PASSWORD=""
SEED_RESET_PASSWORDS="false"
SEED_RESET_PASSWORD_LOGIN_IDS=""
PSMS_MASTER_SEED_PASSWORD=""
